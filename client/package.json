{
  "name": "client",
  "version": "2.3.9",
  "type": "module",
  "description": "This app, rituals.dev, allows you to collaborate with your team to manage your work. It provides teams, sprints, estimate sessions, standup meetings, and retrospectives.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kyleu/rituals.git"
  },
  "keywords": [],
  "author": "kyleu",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kyleu/rituals/issues"
  },
  "homepage": "https://github.com/kyleu/rituals/tree/main/client#readme",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "npm run typecheck && node build.js",
    "build:bundle": "node build.js",
    "build:tsc": "npm run typecheck",
    "dev": "node build.js --watch --dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "cross-spawn": "^7.0.6",
    "esbuild": "^0.27.7",
    "happy-dom": "^20.9.0",
    "oxlint": "^1.14.0",
    "oxlint-tsgolint": "^0.20.0",
    "prettier": "^3.8.3",
    "rollup": ">=4.60.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
